{
  "name": "tpharmagold-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "build": "npm run copy:ffmpeg && next build",
    "copy:ffmpeg": "mkdir -p public/ffmpeg && cp node_modules/@ffmpeg/core/dist/umd/ffmpeg-core.js node_modules/@ffmpeg/core/dist/umd/ffmpeg-core.wasm public/ffmpeg/",
    "postinstall": "npm run copy:ffmpeg",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate:api": "tsx scripts/migrate-from-wix-api.ts",
    "migrate:videos": "tsx scripts/migrate-wix-videos.ts",
    "migrate:videos:dry": "tsx scripts/migrate-wix-videos.ts -- --dry-run",
    "migrate:home-media": "tsx scripts/migrate-home-media.ts",
    "import:media": "tsx scripts/import-wix-media.ts",
    "migrate:csv": "tsx scripts/migrate-from-csv.ts",
    "migrate:images": "tsx scripts/reupload-images.ts",
    "migrate:images:dry": "tsx scripts/reupload-images.ts -- --dry-run",
    "sync:stock": "tsx scripts/sync-stock.ts",
    "migrate:orders": "tsx scripts/migrate-orders.ts",
    "fix:offers": "tsx scripts/fix-offers.ts",
    "backfill:orders": "tsx scripts/backfill-order-fields.ts",
    "backfill:items": "tsx scripts/backfill-order-items.ts",
    "sync:fulfillment": "tsx scripts/sync-fulfillment.ts",
    "migrate:categories": "tsx scripts/migrate-category-images.ts",
    "migrate:contacts": "tsx scripts/migrate-contacts.ts",
    "migrate:reviews": "tsx scripts/migrate-reviews.ts",
    "import:missing-products": "tsx scripts/import-missing-products.ts",
    "consolidate:categories": "tsx scripts/consolidate-categories.ts",
    "backfill:order-items": "tsx scripts/backfill-order-items-wix.ts",
    "backfill:order-phones": "tsx scripts/backfill-order-phones.ts",
    "setup:bootstrap": "tsx scripts/generate-bootstrap-sql.ts",
    "setup:verify": "tsx scripts/verify-setup.ts",
    "setup:wix": "tsx scripts/discover-wix-site.ts",
    "sync:categories": "tsx scripts/sync-product-categories.ts",
    "sync:category-names": "tsx scripts/sync-category-names.ts",
    "sync:product-order": "tsx scripts/sync-product-order-from-wix.ts",
    "print:carousel-order": "tsx scripts/print-wix-carousel-order.ts",
    "scrape:home-carousels": "tsx scripts/scrape-home-carousels.ts",
    "scrape:menu-categories": "tsx scripts/scrape-menu-categories.ts",
    "scrape:category-products": "tsx scripts/scrape-category-products.ts",
    "scrape:pink-kit-testimonios": "tsx scripts/scrape-pink-kit-testimonios.ts",
    "sync:category-order": "tsx scripts/sync-category-order.ts"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "nodemailer": "^8.0.10",
    "quill": "^2.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-quill": "^2.0.0",
    "resend": "^6.12.4",
    "sharp": "^0.35.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "csv-parse": "^6.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
