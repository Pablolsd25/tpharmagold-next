# ── Sitio ───────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.tpharmagold.com

# ── Supabase (proyecto NUEVO — no reutilizar el de Casa Empire) ─
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenPay ───────────────────────────────────────────────────
NEXT_PUBLIC_OPENPAY_MERCHANT_ID=
NEXT_PUBLIC_OPENPAY_PUBLIC_KEY=
OPENPAY_PRIVATE_KEY=
# Producción: false en ambos. Local/sandbox: true en ambos.
NEXT_PUBLIC_OPENPAY_SANDBOX=false
OPENPAY_SANDBOX=false

# ── Admin — emails separados por coma con acceso al panel ─────
ADMIN_EMAILS=contacto@tpharmagold.com

# ── Contacto — bandeja que recibe formulario de contacto ──────
CONTACT_INBOX_EMAIL=tpharmagold@outlook.com

# ── Google Workspace (correos automáticos del sitio) ────────────
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contacto@tpharmagold.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM_EMAIL=contacto@tpharmagold.com
SMTP_FROM_NAME=T Pharma Gold

# SMTP_PASS = contraseña de aplicación de Google (no la contraseña del buzón).

# ── Resend (opcional) ─────────────────────────────────────────
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=no-reply@notificaciones.tpharmagold.com

# ── Brevo (opcional) ──────────────────────────────────────────
# BREVO_API_KEY=
# BREVO_FROM_EMAIL=contacto@tpharmagold.com
# BREVO_FROM_NAME=T Pharma Gold

# ── Wix Migration (solo para importar productos desde Wix) ────
WIX_API_KEY=
WIX_SITE_ID=
WIX_ACCOUNT_ID=
